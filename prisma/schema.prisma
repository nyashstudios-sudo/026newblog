generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  reader
  author
  admin
}

enum AuthorStatus {
  pending
  approved
  rejected
  suspended
}

enum ArticleStatus {
  draft
  in_review
  published
  unpublished
  archived
}

enum NotificationType {
  like
  comment
  reply
  follow
  publish
  mention
  system
  earning
}

enum PayoutStatus {
  pending
  processing
  completed
  failed
}

enum ModerationStatus {
  pending
  approved
  rejected
}

enum ModerationType {
  comment
  article
  spam
}

enum FeedStatus {
  active
  paused
  error
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?   @map("password_hash")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  username      String    @unique
  avatarUrl     String?   @map("avatar_url")
  bio           String?
  website       String?
  role          UserRole  @default(reader)
  isVerified    Boolean   @default(false) @map("is_verified")
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  oauthAccounts           OAuthAccount[]
  sessions                Session[]
  authorApplication       AuthorApplication?
  authorProfile           AuthorProfile?
  articles                Article[]
  articleLikes            ArticleLike[]
  articleSaves            ArticleSave[]
  comments                Comment[]
  commentLikes            CommentLike[]
  followers               Follow[]                 @relation("Following")
  following               Follow[]                 @relation("Follower")
  userInterests           UserInterest[]
  conversationParticipants ConversationParticipant[]
  messagesSent            Message[]
  notifications           Notification[]           @relation("NotificationRecipient")
  notificationsActed      Notification[]           @relation("NotificationActor")
  notificationPreferences NotificationPreferences?
  earnings                Earning[]
  payouts                 Payout[]
  readingSessions         ReadingSession[]
  readingStreak           ReadingStreak?
  readingGoals            ReadingGoals?
  userPin                 UserPin?
  securityEvents          SecurityEvent[]

  @@map("users")
}

model OAuthAccount {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  provider          String
  providerAccountId String   @map("provider_account_id")
  accessToken       String?  @map("access_token")
  refreshToken      String?  @map("refresh_token")
  expiresAt         DateTime? @map("expires_at")
  createdAt         DateTime @default(now()) @map("created_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model Session {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  token      String   @unique
  deviceInfo Json?    @map("device_info")
  ipAddress  String?  @map("ip_address")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model UserPin {
  userId    String   @id @map("user_id")
  pinHash   String   @map("pin_hash")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_pins")
}

model AuthorApplication {
  id                String       @id @default(uuid())
  userId            String       @unique @map("user_id")
  professionalTitle String?      @map("professional_title")
  writingNiche      String?      @map("writing_niche")
  yearsExperience   String?      @map("years_experience")
  portfolioUrl      String?      @map("portfolio_url")
  linkedinUrl       String?      @map("linkedin_url")
  motivation        String?
  sampleFiles       Json         @default("[]") @map("sample_files")
  status            AuthorStatus @default(pending)
  reviewedBy        String?      @map("reviewed_by")
  reviewedAt        DateTime?    @map("reviewed_at")
  rejectionReason   String?      @map("rejection_reason")
  createdAt         DateTime     @default(now()) @map("created_at")
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("author_applications")
}

model AuthorProfile {
  userId          String  @id @map("user_id")
  displayName     String? @map("display_name")
  tagline         String?
  topics          String   @default("[]")
  pinnedArticleId String? @map("pinned_article_id")
  totalViews      BigInt  @default(0) @map("total_views")
  totalLikes      BigInt  @default(0) @map("total_likes")
  totalFollowers  Int     @default(0) @map("total_followers")
  revenueSharePct Float   @default(70.00) @map("revenue_share_pct")
  mpesaPhone      String? @map("mpesa_phone")
  createdAt       DateTime @default(now()) @map("created_at")
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("author_profiles")
}

model Category {
  id           String         @id @default(uuid())
  name         String         @unique
  slug         String         @unique
  description  String?
  icon         String?
  articleCount Int            @default(0) @map("article_count")
  createdAt    DateTime       @default(now()) @map("created_at")
  articles     Article[]
  userInterests UserInterest[]
  rssFeeds     RssFeed[]

  @@map("categories")
}

model Article {
  id                  String        @id @default(uuid())
  authorId            String        @map("author_id")
  title               String
  subtitle            String?
  slug                String        @unique
  content             Json
  contentHtml         String?       @map("content_html")
  excerpt             String?
  coverImageUrl       String?       @map("cover_image_url")
  coverImageCaption   String?       @map("cover_image_caption")
  categoryId          String?       @map("category_id")
  tags                String        @default("[]")
  status              ArticleStatus @default(draft)
  metaDescription     String?       @map("meta_description")
  readingTimeMinutes  Int?          @map("reading_time_minutes")
  wordCount           Int?          @map("word_count")
  viewCount           BigInt        @default(0) @map("view_count")
  likeCount           Int           @default(0) @map("like_count")
  commentCount        Int           @default(0) @map("comment_count")
  shareCount          Int           @default(0) @map("share_count")
  isFeatured          Boolean       @default(false) @map("is_featured")
  publishedAt         DateTime?     @map("published_at")
  scheduledAt         DateTime?     @map("scheduled_at")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category      Category?      @relation(fields: [categoryId], references: [id])
  likes         ArticleLike[]
  saves         ArticleSave[]
  views         ArticleView[]
  comments      Comment[]
  earnings      Earning[]
  notifications Notification[]
  sharedMessages Message[]
  readingSessions ReadingSession[]
  audio         ArticleAudio?

  @@index([categoryId])
  @@index([authorId])
  @@index([publishedAt(sort: Desc)])
  @@map("articles")
}

model ArticleLike {
  userId    String   @map("user_id")
  articleId String   @map("article_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@id([userId, articleId])
  @@map("article_likes")
}

model ArticleSave {
  userId    String   @map("user_id")
  articleId String   @map("article_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@id([userId, articleId])
  @@map("article_saves")
}

model ArticleView {
  id                  String   @id @default(uuid())
  articleId           String   @map("article_id")
  userId              String?  @map("user_id")
  sessionId           String?  @map("session_id")
  ipAddress           String?  @map("ip_address")
  readDurationSeconds Int?     @map("read_duration_seconds")
  scrollDepthPct      Int?     @map("scroll_depth_pct")
  createdAt           DateTime @default(now()) @map("created_at")
  article             Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, createdAt(sort: Desc)])
  @@map("article_views")
}

model Comment {
  id                String           @id @default(uuid())
  articleId         String           @map("article_id")
  userId            String           @map("user_id")
  parentId          String?          @map("parent_id")
  content           String
  likeCount         Int              @default(0) @map("like_count")
  isFlagged         Boolean          @default(false) @map("is_flagged")
  moderationStatus  ModerationStatus @default(approved) @map("moderation_status")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  article       Article        @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent        Comment?       @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]      @relation("CommentReplies")
  likes         CommentLike[]
  notifications Notification[]

  @@index([articleId, createdAt])
  @@map("comments")
}

model CommentLike {
  userId    String   @map("user_id")
  commentId String   @map("comment_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@map("comment_likes")
}

model Follow {
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@map("follows")
}

model UserInterest {
  userId     String   @map("user_id")
  categoryId String   @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@map("user_interests")
}

model Conversation {
  id           String                    @id @default(uuid())
  createdAt    DateTime                  @default(now()) @map("created_at")
  updatedAt    DateTime                  @updatedAt @map("updated_at")
  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  lastReadAt     DateTime? @map("last_read_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id              String   @id @default(uuid())
  conversationId  String   @map("conversation_id")
  senderId        String   @map("sender_id")
  content         String
  attachmentUrl   String?  @map("attachment_url")
  sharedArticleId String?  @map("shared_article_id")
  isRead          Boolean  @default(false) @map("is_read")
  createdAt       DateTime @default(now()) @map("created_at")

  conversation  Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender        User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  sharedArticle Article?     @relation(fields: [sharedArticleId], references: [id])

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String?
  content   String?
  actorId   String?          @map("actor_id")
  articleId String?          @map("article_id")
  commentId String?          @map("comment_id")
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user    User     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor   User?    @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  article Article? @relation(fields: [articleId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

model NotificationPreferences {
  userId            String  @id @map("user_id")
  dailyDigest       Boolean @default(true) @map("daily_digest")
  pushNotifications Boolean @default(true) @map("push_notifications")
  commentReplies    Boolean @default(true) @map("comment_replies")
  newFollowers      Boolean @default(false) @map("new_followers")
  likesOnComments   Boolean @default(false) @map("likes_on_comments")
  weeklyRecap       Boolean @default(true) @map("weekly_recap")
  authorPublishes   Boolean @default(true) @map("author_publishes")
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Earning {
  id          String   @id @default(uuid())
  authorId    String   @map("author_id")
  articleId   String   @map("article_id")
  amountUsd   Float    @map("amount_usd")
  source      String
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  createdAt   DateTime @default(now()) @map("created_at")

  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([authorId, createdAt(sort: Desc)])
  @@map("earnings")
}

model Payout {
  id                 String       @id @default(uuid())
  authorId           String       @map("author_id")
  amountUsd          Float        @map("amount_usd")
  amountKes          Float        @map("amount_kes")
  exchangeRate       Float        @map("exchange_rate")
  feeUsd             Float        @default(0) @map("fee_usd")
  mpesaPhone         String       @map("mpesa_phone")
  mpesaTransactionId String?      @map("mpesa_transaction_id")
  status             PayoutStatus @default(pending)
  processedAt        DateTime?    @map("processed_at")
  failedReason       String?      @map("failed_reason")
  createdAt          DateTime     @default(now()) @map("created_at")

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId, createdAt(sort: Desc)])
  @@map("payouts")
}

model ModerationQueue {
  id           String           @id @default(uuid())
  type         ModerationType
  contentId    String           @map("content_id")
  reportedBy   String           @default("[]") @map("reported_by")
  reason       String?
  aiConfidence Float?           @map("ai_confidence")
  aiCategory   String?          @map("ai_category")
  status       ModerationStatus @default(pending)
  moderatedBy  String?          @map("moderated_by")
  moderatedAt  DateTime?        @map("moderated_at")
  actionTaken  String?          @map("action_taken")
  createdAt    DateTime         @default(now()) @map("created_at")

  @@map("moderation_queue")
}

model RssFeed {
  id                     String     @id @default(uuid())
  name                   String
  url                    String     @unique
  categoryId             String?    @map("category_id")
  refreshIntervalMinutes Int        @default(60) @map("refresh_interval_minutes")
  status                 FeedStatus @default(active)
  lastFetchedAt          DateTime?  @map("last_fetched_at")
  lastError              String?    @map("last_error")
  itemsToday             Int        @default(0) @map("items_today")
  totalItemsImported     Int        @default(0) @map("total_items_imported")
  createdAt              DateTime   @default(now()) @map("created_at")

  category Category? @relation(fields: [categoryId], references: [id])
  items    RssItem[]

  @@map("rss_feeds")
}

model RssItem {
  id          String   @id @default(uuid())
  feedId      String   @map("feed_id")
  guid        String
  title       String
  url         String
  description String?
  author      String?
  publishedAt DateTime? @map("published_at")
  importedAt  DateTime @default(now()) @map("imported_at")

  feed RssFeed @relation(fields: [feedId], references: [id], onDelete: Cascade)

  @@unique([feedId, guid])
  @@index([importedAt(sort: Desc)])
  @@map("rss_items")
}

model ReadingSession {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  articleId       String   @map("article_id")
  durationSeconds Int      @map("duration_seconds")
  completed       Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("reading_sessions")
}

model ReadingStreak {
  userId        String    @id @map("user_id")
  currentStreak Int       @default(0) @map("current_streak")
  longestStreak Int       @default(0) @map("longest_streak")
  lastReadDate  DateTime? @map("last_read_date")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reading_streaks")
}

model ReadingGoals {
  userId            String @id @map("user_id")
  dailyArticles     Int    @default(5) @map("daily_articles")
  weeklyMinutes     Int    @default(120) @map("weekly_minutes")
  weeklyComments    Int    @default(10) @map("weekly_comments")
  weeklyNewTopics   Int    @default(3) @map("weekly_new_topics")
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reading_goals")
}

model ArticleAudio {
  id              String   @id @default(uuid())
  articleId       String   @unique @map("article_id")
  audioUrl        String   @map("audio_url")
  durationSeconds Int      @map("duration_seconds")
  generatedAt     DateTime @default(now()) @map("generated_at")
  voiceModel      String   @default("en-US-Neural2-D") @map("voice_model")
  article         Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("article_audio")
}

model PlatformSetting {
  key       String   @id
  value     Json
  updatedBy String?  @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

model SecurityEvent {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  eventType String   @map("event_type")
  ipAddress String?  @map("ip_address")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@map("security_events")
}
